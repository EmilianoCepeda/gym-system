generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(CLIENT)
  verified    Boolean  @default(false)
  verifyToken String?
  createdAt   DateTime @default(now())

  reservations     Reservation[]
  classes          Class[]
  subscription     Subscription?
  payments         Payment[]
  progressEntries  ProgressEntry[]
  routinesAsCoach  Routine[]       @relation("CoachRoutines")
  routinesAsClient Routine[]       @relation("ClientRoutines")
  schedules        Schedule[]      @relation("CoachSchedules")
  attendanceAsUser Attendance[]    @relation("AttendanceUser")
}

model SubscriptionPlan {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  price       Float
  type        PlanType
  tokenLimit  Int?
  description String?
  createdAt   DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id        Int              @id @default(autoincrement())
  startDate DateTime         @default(now())
  endDate   DateTime
  status    SubscriptionStatus @default(ACTIVE)
  tokens    Int?
  createdAt DateTime         @default(now())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  planId Int
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  payments Payment[]
}

model Payment {
  id        Int      @id @default(autoincrement())
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  userId         Int
  user           User         @relation(fields: [userId], references: [id])

  subscriptionId Int?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
}

model Class {
  id          Int         @id @default(autoincrement())
  name        String
  description String
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  maxCapacity Int
  occupied    Int         @default(0)
  status      ClassStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())

  coachId Int
  coach   User @relation(fields: [coachId], references: [id])

  reservations Reservation[]
  attendances  Attendance[]
}

model Reservation {
  id        Int               @id @default(autoincrement())
  createdAt DateTime          @default(now())
  status    ReservationStatus @default(ACTIVE)

  userId  Int
  user    User  @relation(fields: [userId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  @@unique([userId, classId])
}

model Routine {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  exercises   String
  createdAt   DateTime @default(now())

  coachId  Int
  coach    User @relation("CoachRoutines", fields: [coachId], references: [id])

  clientId Int
  client   User @relation("ClientRoutines", fields: [clientId], references: [id])
}

model ProgressEntry {
  id           Int      @id @default(autoincrement())
  weight       Float?
  height       Float?
  fatIndex     Float?
  muscleMass   Float?
  targetWeight Float?
  targetMuscle Float?
  notes        String?
  createdAt    DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

model Schedule {
  id        Int      @id @default(autoincrement())
  dayOfWeek Int
  startTime String
  endTime   String
  color     String   @default("#FFE000")
  createdAt DateTime @default(now())

  coachId Int
  coach   User @relation("CoachSchedules", fields: [coachId], references: [id])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  attended  Boolean  @default(false)
  createdAt DateTime @default(now())

  userId  Int
  user    User  @relation("AttendanceUser", fields: [userId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  @@unique([userId, classId])
}

enum Role {
  CLIENT
  COACH
  ADMIN
}

enum ClassStatus {
  ACTIVE
  CANCELLED
}

enum ReservationStatus {
  ACTIVE
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PlanType {
  BASIC
  PREMIUM
  GOLD
}