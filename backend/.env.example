NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
PASSWORD_SALT_ROUNDS=12
